{
  "name": "imageprompt-landing",
  "version": "0.1.0",
  "private": true,
  "browserslist": [
    "chrome >= 111",
    "edge >= 111",
    "firefox >= 111",
    "safari >= 16.4",
    "not dead"
  ],
  "scripts": {
    "clean": "rm -rf .next",
    "dev": "next dev -p 3001",
    "build:stv-web": "node scripts/build-stv-web.mjs",
    "sync:stv-sidepanel": "node scripts/sync-stv-web-sidepanel.mjs",
    "build": "npm run build:stv-web && next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "seo:check": "tsx scripts/sync-seo-content.ts --check",
    "seo:sync": "tsx scripts/sync-seo-content.ts --write",
    "backfill:ugc-from-generations": "tsx scripts/backfill-ugc-from-generations.ts",
    "backfill:ugc-from-generations:dry": "tsx scripts/backfill-ugc-from-generations.ts --dry-run",
    "vendor:extension": "esbuild node_modules/@supabase/supabase-js/dist/index.mjs --bundle --format=esm --outfile=../extension/sidepanel/vendor/supabase.js --platform=browser"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.48.0",
    "jose": "^5.10.0",
    "next": "^15.5.7",
    "next-intl": "^3.26.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10",
    "dotenv": "^16.6.1",
    "esbuild": "^0.25.12",
    "eslint": "^9",
    "eslint-config-next": "^15.5.7",
    "postcss": "^8",
    "tailwindcss": "^3.4",
    "tsx": "^4.19.3",
    "typescript": "^5"
  }
}
