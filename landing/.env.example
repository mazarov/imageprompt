# Шаблон переменных. Для локального dev удобнее положить копию как `/.env.local` в корне репозитория (не в `landing/`).
# Supabase (скопировать из photo2sticker-bot/.env)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.dockhost.net
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Достаточно и без NEXT_PUBLIC_* — next.config подставит их для браузера / auth:
# SUPABASE_URL=https://xxx.dockhost.net
# SUPABASE_SUPABASE_PUBLIC_URL=...  # как в server createClient
# SUPABASE_ANON_KEY=eyJ...

# Публичные URL медиа карточек через Storage Image Transformation (imgproxy + ENABLE_IMAGE_TRANSFORMATION на storage-api). Без этого — обычный /object/public/
# NEXT_PUBLIC_SUPABASE_STORAGE_IMAGE_TRANSFORM=1

# Gemini
GEMINI_API_KEY=xxx
GEMINI_PROXY_BASE_URL=https://your-proxy.example.com

# STV / embed / extension: correlate logs across upload → extract → expand → generate
# Client sends header X-STV-Pipeline-Trace (UUID) and pipelineTraceId on POST /api/generate; server logs tag [stv.pipeline] with pipelineTrace.
# GEMINI_VIBE_DEBUG=1 — redacted Gemini request bodies on vibe extract (see landing/src/lib/gemini-vibe-debug-log.ts)
# LANDING_LOG_FULL_GENERATION_PROMPT=0 — disable logging full assembled text in generate-process (default on if unset)
# LANDING_LOG_GEMINI_GENERATE_CONTENT_BODY_REDACTED=1 — redacted multimodal generateContent JSON (no base64) before image-gen fetch
# Optional vibe model overrides if photo_app_config row missing (defaults: extract=gemini-2.5-pro, expand=gemini-2.5-flash)
# GEMINI_VIBE_EXTRACT_MODEL=gemini-2.5-pro
# GEMINI_VIBE_EXPAND_MODEL=gemini-2.5-flash
# One-shot extract: single vision call → { "prompt" }; expand uses vibes.prefilled_generation_prompt (default off; DB photo_app_config.vibe_one_shot_extract_prompt overrides)
# VIBE_ONE_SHOT_EXTRACT_PROMPT=false

# Optional: OpenAI for vibe extract/expand (photo_app_config vibe_extract_llm / vibe_expand_llm = openai)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# VIBE_EXTRACT_LLM=gemini
# VIBE_EXPAND_LLM=openai
# VIBE_OPENAI_EXTRACT_MODEL=gpt-4o
# VIBE_OPENAI_EXPAND_MODEL=gpt-4.1-mini

# Google OAuth (app auth, no Supabase GoTrue)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# If OAuth callback shows oauth_token:fetch failed on VPS/Docker, try:
# NODE_OPTIONS=--dns-result-order=ipv4first
# (Code also retries the token POST via IPv4 https when global fetch fails.)
# HS256 secret for app session JWT (min 16 chars)
AUTH_JWT_SECRET=
# Optional: AUTH_JWT_EXPIRES_DAYS=7, AUTH_SESSION_COOKIE_NAME=ip_session
# Verbose step logs for /auth/google/callback (stdout). Errors always log detail.
# AUTH_CALLBACK_DEBUG=1

# Runtime origin for server-side internal callbacks
NEXT_PUBLIC_SITE_URL=https://imageprompt.tools
# Same-container kickoff for POST /api/generate-process (avoids ETIMEDOUT when public URL is not reachable from inside Docker)
# INTERNAL_GENERATE_PROCESS_ORIGIN=http://127.0.0.1:3001
# robots.txt: Disallow: / (no sitemap). Overrides preview/dev auto-block when set to 0|false|no.
# BLOCK_SEARCH_INDEXING=1

# Marketing page /extension-stv — primary CTA (optional; default #stv-chrome-store)
# NEXT_PUBLIC_STV_CHROME_STORE_URL=https://chromewebstore.google.com/detail/...
# Full URL or bare @username / bot username (API normalizes to https://t.me/...)
TELEGRAM_BOT_LINK=https://t.me/your_payment_bot

# CORS allowlist for chrome extension
# Preferred: set extension id explicitly
CHROME_EXTENSION_ID=abcdefghijklmnopabcdefghijklmnop
# Or use explicit CSV list:
# CORS_ALLOWED_ORIGINS=chrome-extension://abcdefghijklmnopabcdefghijklmnop

# Public "Try this look" CTA on prompt cards
# NEXT_PUBLIC_ENABLE_TRY_THIS_LOOK=true
